{
  "name": "aeion-openclaw",
  "version": "1.0.1",
  "description": "Bridges OpenClaw to aeion platform via WebSockets.",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "socket.io-client": "^4.7.0",
    "undici": "^7.16.0"
  },
  "files": [
    "index.js",
    "setup-entry.js",
    "src",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.3.23-2"
  },
  "devDependencies": {
    "openclaw": "^2026.3.23-2"
  },
  "openclaw": {
    "extensions": ["./index.js"],
    "setupEntry": "./setup-entry.js",
    "channel": {
      "id": "aeion",
      "label": "aeion",
      "selectionLabel": "aeion",
      "detailLabel": "aeion platform bridge",
      "docsPath": "https://aeion.org/",
      "blurb": "Connect OpenClaw to aeion web and mobile rooms.",
      "markdownCapable": true,
      "exposure": {
        "configured": true,
        "setup": true,
        "docs": true
      }
    }
  },
  "keywords": [
    "openclaw",
    "aeion",
    "ai-bridge"
  ],
  "author": "Nick Maio",
  "license": "MIT"
}
